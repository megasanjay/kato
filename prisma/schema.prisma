// Application data model plus Prisma and Kysely client generation targets.
generator client {
    provider        = "prisma-client"
    previewFeatures = ["strictUndefinedChecks"]
    output          = "../shared/generated/"
    engineType      = "client"
}

generator kysely {
    provider = "prisma-kysely"

    output   = "../shared/generated/"
    fileName = "kysely.ts"
}

datasource db {
    provider = "postgresql"
}

model Background {
    id String @id @default(cuid())

    date  String
    theme String

    addTextStroke Boolean @default(false)

    imageID     String @unique
    url         String
    unsplashUrl String

    index Int

    description String

    username     String
    authorName   String
    portfolioUrl String

    city    String
    country String

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model Affirmation {
    id String @id @default(cuid(2))

    date String

    affirmation String

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model User {
    id String @id @default(cuid(2))

    username String @unique
    password String

    emailAddress String? // not required for signup, but can be added later for password reset and email verification

    emailVerified                 Boolean   @default(false)
    emailVerifiedAt               DateTime?
    emailVerificationToken        String?   @unique
    emailVerificationTokenExpires DateTime?

    firstName String @default("")
    lastName  String @default("")

    admin Boolean @default(false)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    currentView CurrentView?

    todos        Todo[]
    notes        Note[]
    countdowns   Countdown[]
    userRssFeeds UserRssFeed[]
}

model CurrentView {
    userId String @id
    user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

    tabName String @default("todo")
}

model Todo {
    id String @id @default(cuid(2))

    userId String
    user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

    content String

    isCompleted Boolean @default(false)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model Note {
    id String @id @default(cuid(2))

    userId String
    user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

    title   String
    content String

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model Countdown {
    id String @id @default(cuid(2))

    userId String
    user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

    title      String
    targetDate DateTime

    recurring       Boolean @default(false)
    recurrenceUnit  String? // "day", "week", "month", "year"
    recurrenceValue Int? // e.g. every 2 weeks, every 3 months

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model RssFeed {
    id String @id @default(cuid(2))

    title String @default("")
    url   String @unique

    lastFetchedAt DateTime?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    rssFeedItems RssFeedItem[]
    userRssFeeds UserRssFeed[]
}

model UserRssFeed {
    id String @id @default(cuid(2))

    userId String
    user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

    feedId String
    feed   RssFeed @relation(fields: [feedId], references: [id], onDelete: Cascade)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@unique([userId, feedId])
}

model RssFeedItem {
    id String @id @default(cuid(2))

    feedId String
    feed   RssFeed @relation(fields: [feedId], references: [id], onDelete: Cascade)

    title       String
    link        String
    pubDate     DateTime
    description String

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}
