{
  "name": "kato",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.15.0",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "start": "node .output/server/index.mjs",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "lint:js": "eslint .",
    "lint:prettier": "prettier --check .",
    "lint": "pnpm lint:js && pnpm lint:prettier",
    "lint:fix": "prettier --write --list-different . && pnpm lint:js --fix",
    "prisma:generate": "prisma generate",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:migrate:dev": "prisma migrate dev --preview-feature",
    "prisma:studio": "prisma studio",
    "prisma:db:push": "prisma db push && pnpm prisma:generate",
    "prisma:db:pull": "prisma db pull",
    "postinstall": "nuxt prepare && prisma generate",
    "scripts:generate:background:images": "tsx ./scripts/generate-background-images.ts",
    "scripts:generate:affirmations": "tsx ./scripts/generate-affirmations.ts",
    "reset": "rimraf node_modules && rimraf .nuxt && rimraf .output && rimraf dist && pnpm install",
    "l-reset": "rm -rf node_modules && rm -rf .nuxt && rm -rf .output && rm -rf dist && pnpm install",
    "prune-branches": "git removed-branches --prune --force"
  },
  "dependencies": {
    "@paralleldrive/cuid2": "3.3.0",
    "@vueuse/core": "14.3.0",
    "bcrypt": "6.0.0",
    "date-fns": "4.1.0",
    "kysely": "0.28.16",
    "kysely-postgres-js": "3.0.0",
    "marked": "18.0.3",
    "prisma-kysely": "3.1.0",
    "sanitize-html": "2.17.3"
  },
  "devDependencies": {
    "@faker-js/faker": "10.4.0",
    "@nuxt/devtools": "4.0.0-alpha.4",
    "@nuxt/eslint": "1.15.2",
    "@nuxt/ui": "4.7.1",
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "@stylistic/eslint-plugin": "5.10.0",
    "@tailwindcss/typography": "0.5.19",
    "@types/bcrypt": "6.0.0",
    "@types/sanitize-html": "2.16.1",
    "@typescript-eslint/parser": "8.59.1",
    "dayjs-nuxt": "2.1.11",
    "eslint": "10.3.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-perfectionist": "5.9.0",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-plugin-unused-imports": "4.4.1",
    "eslint-plugin-vue": "10.9.0",
    "nuxt": "4.4.4",
    "nuxt-auth-utils": "0.5.29",
    "prettier": "3.8.3",
    "prettier-plugin-tailwindcss": "0.8.0",
    "prisma": "7.8.0",
    "rimraf": "6.1.3",
    "tailwindcss": "4.2.4",
    "tailwindcss-debug-screens": "3.0.1",
    "tsx": "4.21.0",
    "typescript": "6.0.3",
    "vue": "latest",
    "zod": "4.4.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "@prisma/engines",
      "bcrypt",
      "esbuild",
      "prisma",
      "unrs-resolver",
      "vue-demi"
    ]
  },
  "engines": {
    "node": "22"
  }
}
